DATABASE_URL="postgresql://user:password@localhost:5432/koyn?schema=public"
JWT_SECRET="change-me-long-random-secret"
CHAIN_ID=8453
# Comma-separated allowed origins for CORS in production
CORS_ORIGINS="http://localhost:3000"

# Web clients with NEXT_PUBLIC_CLIENT_BUILD below this value are blocked until they load a newer bundle.
REQUIRED_CLIENT_BUILD=1

# On-chain KOYN Merkle claim (optional until Alpha/mainnet deploy)
KOYN_TOKEN_ADDRESS=
KOYN_MERKLE_DISTRIBUTOR=
# Set to 1 when running public Alpha (surfaces in GET /claim/info)
ALPHA_PUBLIC=0
